{
  "forms.json": {
    "Chương-trình-Thiền": "Chương-trình-Thiền"
  },
  "page": {
    "form": {
      "id": "Ghi-Danh-Nhập-Học",
      "title": "Ghi Danh Nhập Học",
      "fields": [
        {
          "id": "field_0",
          "name": "Họ và Tên",
          "type": "short_answer",
          "mapping": "name",
          "required": true,
          "placeholder": "Nhập họ và tên"
        },
        {
          "id": "field_1",
          "name": "Pháp Danh",
          "type": "short_answer",
          "required": false,
          "placeholder": "Nhập pháp danh"
        },
        {
          "id": "field_2",
          "name": "Ngày Sinh",
          "type": "date",
          "helpText": "Định dạng: dd/mm/yyyy",
          "required": false,
          "placeholder": "dd/mm/yyyy"
        },
        {
          "id": "field_3",
          "name": "Giới Tính",
          "type": "multiple_choice",
          "options": [
            "Nam",
            "Nữ"
          ],
          "required": true
        },
        {
          "id": "field_4",
          "name": "Email",
          "type": "email_address",
          "mapping": "email",
          "required": true,
          "placeholder": "example@email.com"
        },
        {
          "id": "field_5",
          "name": "Số Điện Thoại",
          "type": "phone_number",
          "required": true,
          "placeholder": "### ### ####"
        },
        {
          "id": "field_6",
          "name": "Chương Trình Học",
          "type": "dropdown",
          "options": [
            "Sơ Cấp",
            "Trung Cấp",
            "Cao Đẳng"
          ],
          "required": true
        },
        {
          "id": "field_7",
          "name": "Hình Thức Tham Gia",
          "type": "dropdown",
          "options": [
            "Trực Tiếp",
            "Trực Tuyến"
          ],
          "required": true
        }
      ]
    },
    "successMessage": "Thank you!"
  }
}