{
    "form": {
        "submit": "email",
        "id": "default_ghi_danh_nhap_hoc",
        "title": "Ghi Danh Nhập Học 2",
        "fields": [
            {
                "name": "Họ và Tên",
                "mapping" : "name",
                "type": "short_answer",
                "required": true,
                "placeholder": "Nhập họ và tên"
            },
            {
                "name": "Pháp Danh",
                "type": "short_answer",
                "placeholder": "Nhập pháp danh"
            },
            {
                "name": "Ngày Sinh",
                "type": "date",
                "placeholder": "dd/mm/yyyy",
                "helpText": "Định dạng: dd/mm/yyyy"
            },
            {
                "name": "Giới Tính",
                "type": "multiple_choice",
                "options": [
                    "Nam",
                    "Nữ"
                ],
                "required": true
            },
            {
              
                "name": "Email",
                "type": "email_address",
                "required": true,
                "mapping" : "email",
                "placeholder": "example@email.com"
            },
            {
             
                "format" : "phone",
                "name": "Số Điện Thoại",
                "type": "phone_number",
                "required": true,
                "placeholder": "### ### ####"
            },
            {
            
                "format" : "text",
                "name": "Chương Trình Học",
                "type": "dropdown",
                "options": [
                    "Sơ Cấp",
                    "Trung Cấp",
                    "Cao Đẳng"
                ],
                "required": true
            },
            {
            
                "format" : "text",
                "name": "Hình Thức Tham Gia",
                "type": "dropdown",
                "options": [
                    "Trực Tiếp",
                    "Trực Tuyến"
                ],
                "required": true
            }
        ]
    }
}
