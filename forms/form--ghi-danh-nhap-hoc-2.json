{
    "title": "GHI DANH NHẬP HỌC",
    "formId": "default_ghi_danh_nhap_hoc",
    "form": {
        "id": "default_ghi_danh_nhap_hoc",
        "title": "Ghi Danh Nhập Học 2",
        "fields": [
            {
                "id": "field_1",
                "format" : "text",
                "name": "Họ và Tên",
                "mapping" : "name",
                "type": "short_answer",
                "required": true,
                "placeholder": "Nhập họ và tên"
            },
            {
                "id": "field_2",
                "format" : "text",
                "name": "Pháp Danh",
                "type": "short_answer",
                "placeholder": "Nhập pháp danh"
            },
            {
                "id": "field_3",
                "format" : "date",
                "name": "Ngày Sinh",
                "type": "short_answer",
                "placeholder": "dd/mm/yyyy",
                "helpText": "Định dạng: dd/mm/yyyy"
            },
            {
                "id": "field_4",
                "format" : "text",
                "name": "Giới Tính",
                "type": "multiple_choice",
                "options": [
                    "Nam",
                    "Nữ"
                ],
                "required": true
            },
            {
                "id": "field_5",
                "name": "email",
                "format" : "email",
                "type": "short_answer",
                "required": true,
                "mapping" : "email",
                "placeholder": "example@email.com",
                "validation": {
                    "mode": "email"
                }
            },
            {
                "id": "field_6",
                "format" : "phone",
                "name": "Số Điện Thoại",
                "type": "short_answer",
                "required": true,
                "placeholder": "0xxx xxx xxx"
            },
            {
                "id": "",
                "format" : "text",
                "name": "Chương Trình Học",
                "type": "dropdown",
                "options": [
                    "Sơ Cấp",
                    "Trung Cấp",
                    "Cao Đẳng"
                ],
                "required": true
            },
            {
                "id": "field_8",
                "format" : "text",
                "name": "Hình Thức Tham Gia",
                "type": "dropdown",
                "options": [
                    "Trực Tiếp",
                    "Trực Tuyến"
                ],
                "required": true
            }
        ]
    }
}
